{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermesops.dev/schemas/hermesfile-v0.schema.json",
  "title": "Hermesfile v0alpha1",
  "description": "Strict declarative sandbox profile source for HermesOps.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "const": "hermesops.dev/v0alpha1"
    },
    "kind": {
      "const": "SandboxProfile"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$",
          "maxLength": 63
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "description": {
          "type": "string",
          "maxLength": 1000
        },
        "labels": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,62}$"
          },
          "additionalProperties": {
            "type": "string",
            "maxLength": 120
          },
          "maxProperties": 64
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base",
        "workspace",
        "runtime",
        "network",
        "security",
        "validation"
      ],
      "properties": {
        "base": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "image",
            "digest"
          ],
          "properties": {
            "registry": {
              "type": "string",
              "maxLength": 253
            },
            "image": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:(?:[._-]|/{1,2})[a-z0-9]+)*$",
              "maxLength": 255
            },
            "tag": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "digest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            }
          }
        },
        "build": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "apt": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "update": {
                  "type": "boolean",
                  "default": true
                },
                "packages": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9+.:~=-]*$",
                    "maxLength": 200
                  },
                  "uniqueItems": true,
                  "maxItems": 256
                }
              }
            },
            "python": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "interpreter": {
                  "type": "string",
                  "enum": [
                    "python3",
                    "python"
                  ]
                },
                "packages": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 300
                  },
                  "uniqueItems": true,
                  "maxItems": 256
                }
              }
            },
            "node": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "packageManager": {
                  "type": "string",
                  "enum": [
                    "npm",
                    "pnpm",
                    "yarn"
                  ]
                },
                "packages": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 300
                  },
                  "uniqueItems": true,
                  "maxItems": 256
                }
              }
            },
            "environment": {
              "type": "object",
              "propertyNames": {
                "pattern": "^[A-Z_][A-Z0-9_]*$"
              },
              "additionalProperties": {
                "type": "string",
                "maxLength": 4096
              },
              "maxProperties": 128
            },
            "steps": {
              "type": "array",
              "maxItems": 128,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "name",
                  "run"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$",
                    "maxLength": 63
                  },
                  "run": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "workingDirectory": {
                    "type": "string",
                    "pattern": "^/(?!$)(?!root(?:/|$))(?!proc(?:/|$))(?!sys(?:/|$))(?!dev(?:/|$))(?!run/docker\\.sock$).+"
                  },
                  "timeout": {
                    "type": "string",
                    "pattern": "^[1-9][0-9]*(?:ms|s|m|h)$"
                  }
                }
              }
            }
          }
        },
        "workspace": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "user",
            "group",
            "directory",
            "sourceMode"
          ],
          "properties": {
            "user": {
              "type": "string",
              "pattern": "^[a-z_][a-z0-9_-]{0,31}$",
              "not": {
                "const": "root"
              }
            },
            "group": {
              "type": "string",
              "pattern": "^[a-z_][a-z0-9_-]{0,31}$",
              "not": {
                "const": "root"
              }
            },
            "directory": {
              "type": "string",
              "pattern": "^/(?!$)(?!root(?:/|$))(?!proc(?:/|$))(?!sys(?:/|$))(?!dev(?:/|$))(?!run/docker\\.sock$).+"
            },
            "sourceMode": {
              "type": "string",
              "enum": [
                "worktree",
                "clone",
                "readOnly"
              ]
            }
          }
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "cpu",
            "memory",
            "pids",
            "timeout",
            "stopGracePeriod"
          ],
          "properties": {
            "cpu": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 256
            },
            "memory": {
              "type": "string",
              "pattern": "^[1-9][0-9]*(?:\\.[0-9]+)?(?:KiB|MiB|GiB|TiB)$"
            },
            "pids": {
              "type": "integer",
              "minimum": 16,
              "maximum": 65536
            },
            "timeout": {
              "type": "string",
              "pattern": "^[1-9][0-9]*(?:ms|s|m|h)$"
            },
            "stopGracePeriod": {
              "type": "string",
              "pattern": "^[1-9][0-9]*(?:ms|s|m|h)$"
            },
            "tmpfsSize": {
              "type": "string",
              "pattern": "^[1-9][0-9]*(?:\\.[0-9]+)?(?:KiB|MiB|GiB|TiB)$"
            }
          }
        },
        "network": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "build",
            "runtime"
          ],
          "properties": {
            "build": {
              "$ref": "#/$defs/networkPolicy"
            },
            "runtime": {
              "$ref": "#/$defs/networkPolicy"
            }
          }
        },
        "security": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "privileged",
            "noNewPrivileges",
            "readOnlyRoot",
            "capabilities",
            "seccompProfile",
            "allowSecrets",
            "allowDockerSocket",
            "allowDeviceAccess"
          ],
          "properties": {
            "privileged": {
              "const": false
            },
            "noNewPrivileges": {
              "const": true
            },
            "readOnlyRoot": {
              "type": "boolean"
            },
            "capabilities": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "drop",
                "add"
              ],
              "properties": {
                "drop": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "contains": {
                    "const": "ALL"
                  },
                  "minContains": 1,
                  "uniqueItems": true
                },
                "add": {
                  "type": "array",
                  "maxItems": 0
                }
              }
            },
            "seccompProfile": {
              "type": "string",
              "enum": [
                "default"
              ]
            },
            "allowSecrets": {
              "type": "boolean"
            },
            "allowDockerSocket": {
              "const": false
            },
            "allowDeviceAccess": {
              "const": false
            }
          }
        },
        "mounts": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "type",
              "target",
              "readOnly"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$",
                "maxLength": 63
              },
              "type": {
                "type": "string",
                "enum": [
                  "workspace",
                  "cache",
                  "tmpfs",
                  "artifact"
                ]
              },
              "target": {
                "type": "string",
                "pattern": "^/(?!$)(?!root(?:/|$))(?!proc(?:/|$))(?!sys(?:/|$))(?!dev(?:/|$))(?!run/docker\\.sock$).+"
              },
              "readOnly": {
                "type": "boolean"
              },
              "size": {
                "type": "string",
                "pattern": "^[1-9][0-9]*(?:\\.[0-9]+)?(?:KiB|MiB|GiB|TiB)$"
              }
            }
          }
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "commands"
          ],
          "properties": {
            "commands": {
              "type": "array",
              "minItems": 1,
              "maxItems": 128,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "name",
                  "run",
                  "timeout",
                  "expectExitCode"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$",
                    "maxLength": 63
                  },
                  "run": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "timeout": {
                    "type": "string",
                    "pattern": "^[1-9][0-9]*(?:ms|s|m|h)$"
                  },
                  "expectExitCode": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 255
                  },
                  "workingDirectory": {
                    "type": "string",
                    "pattern": "^/(?!$)(?!root(?:/|$))(?!proc(?:/|$))(?!sys(?:/|$))(?!dev(?:/|$))(?!run/docker\\.sock$).+"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "allow"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "allowlist",
            "full"
          ]
        },
        "allow": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 253,
            "not": {
              "pattern": "(?i)(token|password|secret|key)="
            }
          },
          "uniqueItems": true,
          "maxItems": 256
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "none"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "properties": {
              "allow": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "allowlist"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "properties": {
              "allow": {
                "minItems": 1
              }
            }
          }
        }
      ]
    }
  },
  "examples": [
    {
      "apiVersion": "hermesops.dev/v0alpha1",
      "kind": "SandboxProfile",
      "metadata": {
        "name": "python-project",
        "displayName": "Python Project Worker"
      },
      "spec": {
        "base": {
          "image": "python",
          "tag": "3.12.10-slim-bookworm",
          "digest": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
        },
        "workspace": {
          "user": "hermes",
          "group": "hermes",
          "directory": "/workspace",
          "sourceMode": "worktree"
        },
        "runtime": {
          "cpu": 4,
          "memory": "8GiB",
          "pids": 512,
          "timeout": "2h",
          "stopGracePeriod": "30s",
          "tmpfsSize": "1GiB"
        },
        "network": {
          "build": {
            "mode": "allowlist",
            "allow": [
              "deb.debian.org",
              "pypi.org",
              "files.pythonhosted.org"
            ]
          },
          "runtime": {
            "mode": "none",
            "allow": []
          }
        },
        "security": {
          "privileged": false,
          "noNewPrivileges": true,
          "readOnlyRoot": false,
          "capabilities": {
            "drop": [
              "ALL"
            ],
            "add": []
          },
          "seccompProfile": "default",
          "allowSecrets": false,
          "allowDockerSocket": false,
          "allowDeviceAccess": false
        },
        "mounts": [
          {
            "name": "artifacts",
            "type": "artifact",
            "target": "/artifacts",
            "readOnly": false
          }
        ],
        "validation": {
          "commands": [
            {
              "name": "python",
              "run": [
                "python3",
                "--version"
              ],
              "timeout": "30s",
              "expectExitCode": 0
            }
          ]
        }
      }
    }
  ]
}
