{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermesops.dev/schemas/hermesfile-v1.schema.json",
  "title": "Hermesfile v1",
  "description": "Strict executable source contract for one HermesOps sandbox profile.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "const": "hermesops.dev/v1"
    },
    "kind": {
      "const": "SandboxProfile"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$",
          "maxLength": 63
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "description": {
          "type": "string",
          "maxLength": 1000
        },
        "labels": {
          "type": "object",
          "maxProperties": 64,
          "propertyNames": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,62}$"
          },
          "additionalProperties": {
            "type": "string",
            "maxLength": 120
          }
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base",
        "workspace",
        "runtime",
        "network",
        "security",
        "validation"
      ],
      "properties": {
        "base": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "image",
            "digest"
          ],
          "properties": {
            "registry": {
              "type": "string",
              "minLength": 1,
              "maxLength": 253,
              "default": "docker.io"
            },
            "image": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:(?:[._-]|/{1,2})[a-z0-9]+)*$",
              "maxLength": 255
            },
            "tag": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "digest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            }
          }
        },
        "build": {
          "type": "object",
          "additionalProperties": false,
          "default": {},
          "properties": {
            "apt": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "update": {
                  "type": "boolean",
                  "default": true
                },
                "packages": {
                  "type": "array",
                  "uniqueItems": true,
                  "maxItems": 256,
                  "default": [],
                  "items": {
                    "type": "string",
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9+.:~=@/_-]*$",
                    "maxLength": 300
                  }
                }
              }
            },
            "python": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "interpreter": {
                  "type": "string",
                  "enum": [
                    "python3",
                    "python"
                  ],
                  "default": "python3"
                },
                "packages": {
                  "type": "array",
                  "uniqueItems": true,
                  "maxItems": 256,
                  "default": [],
                  "items": {
                    "type": "string",
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9+.:~=@/_-]*$",
                    "maxLength": 300
                  }
                }
              }
            },
            "node": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "packageManager": {
                  "type": "string",
                  "enum": [
                    "npm",
                    "pnpm",
                    "yarn"
                  ],
                  "default": "npm"
                },
                "packages": {
                  "type": "array",
                  "uniqueItems": true,
                  "maxItems": 256,
                  "default": [],
                  "items": {
                    "type": "string",
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9+.:~=@/_-]*$",
                    "maxLength": 300
                  }
                }
              }
            },
            "environment": {
              "type": "object",
              "maxProperties": 128,
              "default": {},
              "propertyNames": {
                "pattern": "^[A-Z_][A-Z0-9_]*$",
                "not": {
                  "pattern": "(?i)(?:^|_)(?:API_?KEY|AUTH|CREDENTIAL|PASSWORD|PRIVATE_?KEY|SECRET|TOKEN)(?:_|$)"
                }
              },
              "additionalProperties": {
                "type": "string",
                "maxLength": 4096,
                "not": {
                  "pattern": "(?i)(?:\\$\\{|token\\s*=|password\\s*=|secret\\s*=|api[_-]?key\\s*=|https?://[^/\\s:@]+:[^/\\s@]+@|-{5}BEGIN [A-Z0-9 ]*PRIVATE KEY-{5})"
                }
              }
            },
            "steps": {
              "type": "array",
              "maxItems": 128,
              "default": [],
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "name",
                  "run",
                  "timeout"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$",
                    "maxLength": 63
                  },
                  "run": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 64,
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 4096
                    }
                  },
                  "timeout": {
                    "type": "string",
                    "pattern": "^[1-9][0-9]*(?:ms|s|m|h)$"
                  },
                  "workingDirectory": {
                    "type": "string",
                    "pattern": "^/(?!$)(?!bin(?:/|$))(?!boot(?:/|$))(?!dev(?:/|$))(?!etc(?:/|$))(?!lib(?:/|$))(?!lib64(?:/|$))(?!proc(?:/|$))(?!root(?:/|$))(?!run(?:/|$))(?!sbin(?:/|$))(?!sys(?:/|$))(?!usr(?:/|$))(?!var/run(?:/|$))(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?:.*[^/])$",
                    "maxLength": 4096
                  }
                }
              }
            }
          }
        },
        "workspace": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "user",
            "group",
            "directory",
            "sourceMode"
          ],
          "properties": {
            "user": {
              "type": "string",
              "pattern": "^[a-z_][a-z0-9_-]{0,31}$",
              "not": {
                "const": "root"
              }
            },
            "group": {
              "type": "string",
              "pattern": "^[a-z_][a-z0-9_-]{0,31}$",
              "not": {
                "const": "root"
              }
            },
            "directory": {
              "type": "string",
              "pattern": "^/(?!$)(?!bin(?:/|$))(?!boot(?:/|$))(?!dev(?:/|$))(?!etc(?:/|$))(?!lib(?:/|$))(?!lib64(?:/|$))(?!proc(?:/|$))(?!root(?:/|$))(?!run(?:/|$))(?!sbin(?:/|$))(?!sys(?:/|$))(?!usr(?:/|$))(?!var/run(?:/|$))(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?:.*[^/])$",
              "maxLength": 4096
            },
            "sourceMode": {
              "type": "string",
              "enum": [
                "worktree",
                "clone",
                "readOnly"
              ]
            }
          }
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "cpu",
            "memory",
            "pids",
            "timeout",
            "stopGracePeriod"
          ],
          "properties": {
            "cpu": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 256
            },
            "memory": {
              "type": "string",
              "pattern": "^[1-9][0-9]*(?:\\.[0-9]+)?(?:KiB|MiB|GiB|TiB)$"
            },
            "pids": {
              "type": "integer",
              "minimum": 16,
              "maximum": 65536
            },
            "timeout": {
              "type": "string",
              "pattern": "^[1-9][0-9]*(?:ms|s|m|h)$"
            },
            "stopGracePeriod": {
              "type": "string",
              "pattern": "^[1-9][0-9]*(?:ms|s|m|h)$"
            },
            "tmpfsSize": {
              "type": "string",
              "pattern": "^[1-9][0-9]*(?:\\.[0-9]+)?(?:KiB|MiB|GiB|TiB)$"
            }
          }
        },
        "network": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "build",
            "runtime"
          ],
          "properties": {
            "build": {
              "$ref": "#/$defs/networkPolicy"
            },
            "runtime": {
              "$ref": "#/$defs/networkPolicy"
            }
          }
        },
        "security": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "privileged",
            "noNewPrivileges",
            "readOnlyRoot",
            "capabilities",
            "seccompProfile",
            "secrets",
            "allowDockerSocket",
            "allowDeviceAccess"
          ],
          "properties": {
            "privileged": {
              "const": false
            },
            "noNewPrivileges": {
              "const": true
            },
            "readOnlyRoot": {
              "type": "boolean"
            },
            "capabilities": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "drop",
                "add"
              ],
              "properties": {
                "drop": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "contains": {
                    "const": "ALL"
                  },
                  "minContains": 1,
                  "items": {
                    "type": "string",
                    "maxLength": 64
                  }
                },
                "add": {
                  "type": "array",
                  "maxItems": 0
                }
              }
            },
            "seccompProfile": {
              "const": "default"
            },
            "secrets": {
              "const": false
            },
            "allowDockerSocket": {
              "const": false
            },
            "allowDeviceAccess": {
              "const": false
            }
          }
        },
        "mounts": {
          "type": "array",
          "maxItems": 64,
          "default": [],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "type",
              "target",
              "readOnly"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$",
                "maxLength": 63
              },
              "type": {
                "type": "string",
                "enum": [
                  "workspace",
                  "cache",
                  "tmpfs",
                  "artifact"
                ]
              },
              "target": {
                "type": "string",
                "pattern": "^/(?!$)(?!bin(?:/|$))(?!boot(?:/|$))(?!dev(?:/|$))(?!etc(?:/|$))(?!lib(?:/|$))(?!lib64(?:/|$))(?!proc(?:/|$))(?!root(?:/|$))(?!run(?:/|$))(?!sbin(?:/|$))(?!sys(?:/|$))(?!usr(?:/|$))(?!var/run(?:/|$))(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?:.*[^/])$",
                "maxLength": 4096
              },
              "readOnly": {
                "type": "boolean"
              },
              "size": {
                "type": "string",
                "pattern": "^[1-9][0-9]*(?:\\.[0-9]+)?(?:KiB|MiB|GiB|TiB)$"
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "type": {
                      "const": "tmpfs"
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                "then": {
                  "required": [
                    "size"
                  ]
                }
              }
            ]
          }
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "commands"
          ],
          "properties": {
            "commands": {
              "type": "array",
              "minItems": 1,
              "maxItems": 128,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "name",
                  "run",
                  "timeout",
                  "expectExitCode"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$",
                    "maxLength": 63
                  },
                  "run": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 64,
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 4096
                    }
                  },
                  "timeout": {
                    "type": "string",
                    "pattern": "^[1-9][0-9]*(?:ms|s|m|h)$"
                  },
                  "workingDirectory": {
                    "type": "string",
                    "pattern": "^/(?!$)(?!bin(?:/|$))(?!boot(?:/|$))(?!dev(?:/|$))(?!etc(?:/|$))(?!lib(?:/|$))(?!lib64(?:/|$))(?!proc(?:/|$))(?!root(?:/|$))(?!run(?:/|$))(?!sbin(?:/|$))(?!sys(?:/|$))(?!usr(?:/|$))(?!var/run(?:/|$))(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?:.*[^/])$",
                    "maxLength": 4096
                  },
                  "expectExitCode": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 255
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "allow"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "allowlist",
            "full"
          ]
        },
        "allow": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 256,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 253
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "none"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "properties": {
              "allow": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "allowlist"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "properties": {
              "allow": {
                "minItems": 1
              }
            }
          }
        }
      ]
    }
  }
}
